!\n","image":{"type":"ImageBlock","url":"/images/partner/student-ecocamps/Pioneers Icon.webp","altText":"2025 Summer Yunnan Sustainability Pioneers Program","styles":{"self":{"borderRadius":"x-large"}},"__metadata":{"modelName":"ImageBlock"}},"actions":[{"type":"Button","label":"Learn More","altText":"","url":"https://mp.weixin.qq.com/s/bt4J-jGaAgB_rR7bapT9rA","showIcon":false,"icon":"arrowRight","iconPosition":"right","style":"primary","elementId":"","__metadata":{"modelName":"Button"}}],"colors":"bg-light-fg-dark","styles":{"self":{"padding":["pt-0","pl-0","pb-3","pr-0"],"borderRadius":"x-large","flexDirection":"col","textAlign":"center","justifyContent":"center"}},"__metadata":{"modelName":"FeaturedItem"}}],"actions":[],"variant":"two-col-grid","colors":"bg-neutral-fg-dark","styles":{"self":{"padding":["pt-9","pl-3","pb-9","pr-3"],"justifyContent":"center"},"subtitle":{"textAlign":"center"}},"__metadata":{"modelName":"FeaturedItemsSection"}},{"type":"GenericSection","title":{"type":"TitleBlock","text":"","color":"text-dark","__metadata":{"modelName":"TitleBlock"}},"subtitle":"","text":"","actions":[],"media":{"type":"ImageBlock","altText":"Dope design preview","__metadata":{"modelName":"ImageBlock"}},"badge":{"type":"Badge","label":"","color":"text-primary","__metadata":{"modelName":"Badge"}},"colors":"bg-light-fg-dark","styles":{"self":{"alignItems":"center","flexDirection":"row-reverse","padding":["pb-0"]}},"__metadata":{"modelName":"GenericSection"}},{"type":"GenericSection","title":{"type":"TitleBlock","text":"Inquiry and Booking","color":"text-light","styles":{"self":{"textAlign":"center","fontWeight":400}},"__metadata":{"modelName":"TitleBlock"}},"subtitle":"","text":"Contact Us to Discuss Your Sustainability Adventure!\n","actions":[{"type":"Button","label":"Contact Us","altText":"","url":"/contact-us","showIcon":false,"icon":"arrowRight","iconPosition":"right","style":"primary","elementId":"","__metadata":{"modelName":"Button"}}],"colors":"bg-dark-fg-ligh