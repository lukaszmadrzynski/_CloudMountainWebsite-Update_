# Cloud Mountain Website — Environment Variables
#
# Copy this file to `.env.local` for local development.
# In Cloudflare Pages, set these under:
#   Project > Settings > Environment variables
# (the build reads them at build time; output: 'export' inlines them into the bundle)

# Google Analytics 4 measurement ID (public, safe to commit in client bundle)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-JG1RTRLGQJ

# Cloudflare Turnstile site key (public, safe in client bundle).
# Get this from: Cloudflare Account > Turnstile > your widget > Site key
# If unset, the Turnstile widget won't render on the contact/booking forms
# (the form still works, just without bot protection).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Worker URL that receives contact-form POST submissions.
# Reached via a Cloudflare Workers Route on the apex domain — same-origin,
# so the request is not exposed to GFW throttling of `workers.dev`.
# Route: cloudmountain.top/api/contact* -> contact-form Worker
# (configured in Cloudflare dashboard: Workers & Pages > contact-form > Triggers > Routes)
NEXT_PUBLIC_CONTACT_FORM_WORKER_URL=https://cloudmountain.top/api/contact

# IMPORTANT: Turnstile SECRET key (private, server-side only)
# This must NEVER be in this repo or in any client bundle.
# Set it as a Cloudflare Worker secret:
#   cd worker-directory && wrangler secret put TURNSTILE_SECRET_KEY
# The Worker reads it from event.env.TURNSTILE_SECRET_KEY and uses it to verify
# the cf-turnstile-response token via POST to challenges.cloudflare.com/turnstile/v0/siteverify.
# TURNSTILE_SECRET_KEY=

# Algolia (currently DISABLED at runtime - blog/index.md has enableSearch: false)
# Re-enable by removing enableSearch:false from content/pages/blog/index.md and
# populating these with values from your Algolia dashboard.
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_INDEX_NAME=
# NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
# ALGOLIA_ADMIN_API_KEY=
